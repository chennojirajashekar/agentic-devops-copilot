# ============================================================
# Agentic DevOps Copilot - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-agentic-devops
AZURE_LOCATION=eastus

# --- Azure AI Foundry ---
AZURE_AI_PROJECT_NAME=agentic-devops-project
AZURE_AI_PROJECT_HOST=https://<your-project>.services.ai.azure.com
AZURE_AI_CONNECTION_STRING=<region>.api.azureml.ms;<subscription-id>;<resource-group>;<workspace>

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Azure Monitor / Application Insights ---
AZURE_MONITOR_WORKSPACE_ID=your-log-analytics-workspace-id
AZURE_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx
AZURE_APP_INSIGHTS_APP_ID=your-app-insights-app-id
AZURE_APP_INSIGHTS_API_KEY=your-app-insights-api-key

# --- GitHub ---
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO_OWNER=chennojirajashekar
GITHUB_REPO_NAME=agentic-devops-copilot
GITHUB_DEFAULT_BRANCH=main

# --- Azure DevOps (optional, use GitHub or ADO) ---
AZURE_DEVOPS_ORG=https://dev.azure.com/your-org
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_TOKEN=your-ado-pat

# --- Cosmos DB (state store) ---
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=agentic-devops
COSMOS_CONTAINER=incidents

# --- Agent Configuration ---
AUTOMATION_LEVEL=semi-auto
# Options: notify-only | semi-auto | full-auto
RISK_THRESHOLD=medium
# Options: low | medium | high
HUMAN_APPROVAL_REQUIRED=true
MAX_RETRY_ATTEMPTS=3
AGENT_TIMEOUT_SECONDS=120
